/*
 * app.overlay — STM32WB55 BLDC Motor Controller
 *
 * CPU:   Cortex-M4 @ 64 MHz (via PLL from 32 MHz HSE)
 * TIM1:  on APB2 — clock = 64 MHz (APB2 prescaler = 1, no x2 multiplier)
 *        ARR = 3200 → PWM freq = 64,000,000 / 3200 = 20 kHz  ✓
 *
 * Hall sensors remapped to PC0/PC1/PC3 (CN7 right side pins 28/30/36)
 * Original PC2/PA0/PA1 replaced due to suspected GPIO damage.
 *
 * Physical connections on CN7 right side:
 *   PC0 → CN7 pin 28  ← HU (yellow)
 *   PC1 → CN7 pin 30  ← HV (white)
 *   PC3 → CN7 pin 36  ← HW (green)
 *   GND → CN7 pin 08
 *   5V  → CN7 pin 18  (5V_EXT) for pull-up resistors and motor 5VO
 */

/ {
    aliases {
        hall-u = &hall_u_pin;
        hall-v = &hall_v_pin;
        hall-w = &hall_w_pin;
    };

    hall_sensors {
        compatible = "gpio-keys";

        hall_u_pin: hall_u {
            gpios = <&gpioc 2 GPIO_ACTIVE_HIGH>;  /* PC2 — CN7 pin 38 */
            label = "HALL_U";
        };
        hall_v_pin: hall_v {
            gpios = <&gpioc 3 GPIO_ACTIVE_HIGH>;  /* PC3 — CN7 pin 36 */
            label = "HALL_V";
        };
        hall_w_pin: hall_w {
            gpios = <&gpioa 1 GPIO_ACTIVE_HIGH>;  /* PA1 — CN7 pin 32 */
            label = "HALL_W";
        };
    };
};

/*
 * Clock tree for STM32WB55:
 *   HSE = 32 MHz → PLL (×2) → SYSCLK = 64 MHz
 *   AHB  prescaler = 1 → HCLK  = 64 MHz
 *   APB1 prescaler = 1 → PCLK1 = 64 MHz
 *   APB2 prescaler = 1 → PCLK2 = 64 MHz  (TIM1 lives here)
 */
&rcc {
    clocks = <&pll>;
    clock-frequency = <DT_FREQ_M(64)>;
    cpu1-prescaler  = <1>;
    cpu2-prescaler  = <2>;
    ahb4-prescaler  = <1>;
    apb1-prescaler  = <1>;
    apb2-prescaler  = <1>;
};

&pll {
    div-m  = <2>;
    mul-n  = <8>;
    div-q  = <2>;
    div-r  = <2>;
    clocks = <&clk_hse>;
    status = "okay";
};

/*
 * TIM1 — Advanced Motor Control Timer @ 64 MHz
 */
&timers1 {
    status = "okay";

    pwm1: pwm {
        status = "okay";
        pinctrl-0 = <&pwm1_ch1_pa8   &pwm1_ch2_pa9   &pwm1_ch3_pa10
                     &pwm1_ch1n_pb13  &pwm1_ch2n_pb14  &pwm1_ch3n_pb15>;
        pinctrl-names = "default";
    };
};

&pinctrl {

    /* High-side switches */
    pwm1_ch1_pa8: pwm1_ch1_pa8 {
        pinmux = <STM32_PINMUX('A', 8,  AF1)>;  /* TIM1_CH1  — Phase U high */
        drive-push-pull;
    };
    pwm1_ch2_pa9: pwm1_ch2_pa9 {
        pinmux = <STM32_PINMUX('A', 9,  AF1)>;  /* TIM1_CH2  — Phase V high */
        drive-push-pull;
    };
    pwm1_ch3_pa10: pwm1_ch3_pa10 {
        pinmux = <STM32_PINMUX('A', 10, AF1)>;  /* TIM1_CH3  — Phase W high */
        drive-push-pull;
    };

    /* Low-side switches (complementary) */
    pwm1_ch1n_pb13: pwm1_ch1n_pb13 {
        pinmux = <STM32_PINMUX('B', 13, AF1)>;  /* TIM1_CH1N — Phase U low */
        drive-push-pull;
    };
    pwm1_ch2n_pb14: pwm1_ch2n_pb14 {
        pinmux = <STM32_PINMUX('B', 14, AF1)>;  /* TIM1_CH2N — Phase V low */
        drive-push-pull;
    };
    pwm1_ch3n_pb15: pwm1_ch3n_pb15 {
        pinmux = <STM32_PINMUX('B', 15, AF1)>;  /* TIM1_CH3N — Phase W low */
        drive-push-pull;
    };
};
